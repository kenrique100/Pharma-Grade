# Copy this file to .env.local and fill in your values
# Required for NextAuth.js authentication
#
# Generate AUTH_SECRET with one of these methods:
#   npx auth secret
#   openssl rand -base64 32
#   https://generate-secret.vercel.app/32
#
# On Vercel: add these in Dashboard → Settings → Environment Variables
AUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=https://your-app.vercel.app

# Optional: Google OAuth (enables Google sign-in/sign-up buttons)
# Create credentials at https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Database URL (for production - replace JSON store with a real DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/pharmagrade

# Optional: Email (for real OTP and verification emails)
# RESEND_API_KEY=re_...
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password

# Optional: Cloudinary for image uploads
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
