# ══════════════════════════════════════════════════════════════════
#  Pharma Grade — Environment Variables
#  Copy this file to .env.local, then fill in every value.
#  NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────
#
# Recommended: Neon (https://neon.tech) — free PostgreSQL, 0.5 GB storage
#   Other options: Supabase (https://supabase.com) | Railway (https://railway.app)
#
# Connection string format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pharmagrade?sslmode=require

# If you are using a connection pooler such as Neon's PgBouncer or Supabase's
# transaction-mode pooler, set DIRECT_URL to the NON-pooled connection string.
# Prisma migrations and the seed script require a direct (non-pooled) connection
# to execute DDL statements correctly. If DIRECT_URL is not set, DATABASE_URL
# is used for both the app and migrations.
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/pharmagrade?sslmode=require

# ── better-auth ────────────────────────────────────────────────────
#
# Generate BETTER_AUTH_SECRET:
#   openssl rand -base64 32
#   https://generate-secret.vercel.app/32
#
BETTER_AUTH_SECRET=replace-with-a-random-32-char-secret

# Your deployed app URL (no trailing slash).
# For local dev use: http://localhost:3000
BETTER_AUTH_URL=https://your-app.vercel.app

# Exposed to the browser (used by the auth client)
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-app.vercel.app

# Comma-separated list of trusted origins (e.g. your frontend domain)
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-app.vercel.app

# ── Google OAuth (optional) ────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Seed script defaults (optional) ───────────────────────────────
# Override the default admin password used by `npm run db:seed`.
# ⚠️  Change these BEFORE running the seed script in production!
# ADMIN_EMAIL=admin@pharmagrade.com
# ADMIN_PASSWORD=change-me-in-production
# USER_PASSWORD=change-me-in-production

# ── Live Chat email notifications (Resend) ─────────────────────────
#
# Resend is the recommended email provider for this stack:
#   ✅ Free tier: 100 emails/day, 3 000/month
#   ✅ Zero SMTP config — works natively with Vercel / serverless
#   ✅ Simple Next.js integration
#
# Sign up at https://resend.com, verify your domain, paste the API key.
# RESEND_API_KEY=re_...
# ADMIN_EMAIL=admin@yourdomain.com
# FROM_EMAIL=support@yourdomain.com

# ── Cloudinary (optional — product image / licence uploads) ────────
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
