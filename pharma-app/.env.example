# Copy this file to .env.local and fill in your values
# Required for NextAuth.js authentication
#
# Generate AUTH_SECRET with one of these methods:
#   npx auth secret
#   openssl rand -base64 32
#   https://generate-secret.vercel.app/32
#
# On Vercel: add these in Dashboard → Settings → Environment Variables
AUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=https://your-app.vercel.app

# Optional: Google OAuth (enables Google sign-in/sign-up buttons)
# Create credentials at https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Database URL (for production - replace in-memory store with a real DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/pharmagrade

# Email notifications for Live Chat (via Resend — https://resend.com)
# Resend is highly recommended for this system:
#   ✅ Free tier: 100 emails/day, 3000/month — sufficient for a support chat system
#   ✅ Simple Next.js/serverless integration — no SMTP config needed
#   ✅ Reliable delivery & modern developer experience
#   ✅ Works perfectly with Vercel Edge / serverless functions
# Sign up at https://resend.com, verify your domain, and paste the API key below.
# RESEND_API_KEY=re_...
# ADMIN_EMAIL=admin@yourdomain.com
# FROM_EMAIL=support@yourdomain.com

# Optional: Cloudinary for image uploads (product images / licences)
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
