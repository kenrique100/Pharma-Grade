# Copy this file to .env.local and fill in your values
# Required for NextAuth.js authentication
AUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Optional: Database URL (for production - replace JSON store with a real DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/pharmagrade

# Optional: Stripe for real payments
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: Email (Resend or SMTP for order confirmations)
# RESEND_API_KEY=re_...

# Optional: Cloudinary for image uploads
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
