generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("user") // "admin" | "user"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  userEmail String
  userName  String
  text      String
  from      String
  timestamp DateTime @default(now())

  @@index([sessionId])
  @@index([timestamp])
}
